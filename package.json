{
  "name": "@ac-comp-lib/component-library",
  "version": "0.1.2",
  "description": "Framework-agnostic component library: HTML structure + CSS. Use with React, Vue, vanilla JS, or any stack.",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chis-adobe/ac-component-library.git"
  },
  "bugs": {
    "url": "https://github.com/chis-adobe/ac-component-library/issues"
  },
  "exports": {
    "./promo-banner": "./dist/promo-banner.css",
    "./promo-banner/react": {
      "import": "./src/react.tsx",
      "types": "./src/react.tsx"
    },
    "./promo-banner/template": "./templates/promo-banner.html",
    "./promo-banner/template/skeleton": "./templates/promo-banner-skeleton.html"
  },
  "files": [
    "dist",
    "templates",
    "src"
  ],
  "scripts": {},
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "keywords": [
    "components",
    "air-canada",
    "css",
    "html",
    "promo-banner"
  ],
  "license": "MIT"
}
